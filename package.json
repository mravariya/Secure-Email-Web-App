{
  "name": "secure-email-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "workers/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=apps/web-client",
    "dev:api": "npm run dev --workspace=apps/api-server",
    "dev:imap": "npm run dev -w imap-sync",
    "dev:smtp": "npm run dev -w smtp-worker",
    "db:migrate": "npm run migrate --workspace=packages/database",
    "db:generate": "npm run generate --workspace=packages/database",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  },
  "engines": {
    "node": ">=18"
  }
}
